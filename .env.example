# HTTP port for the admin/config UI (configurable for reverse proxy / add-on setups)
PORT=3000

# Path to the SQLite database file.
#   Local dev:            ./data/bridge.db
#   Docker / HA add-on:   /data/bridge.db  (already set in the Dockerfile / add-on config)
DB_PATH=./data/bridge.db

# Log level: trace | debug | info | warn | error — all logs go to stdout so any
# container / add-on supervisor can capture them.
LOG_LEVEL=info

# Max number of log lines kept in-memory for the /logs page
LOG_BUFFER_SIZE=500
